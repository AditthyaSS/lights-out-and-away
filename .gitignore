# ============================================================
# Lights Out and Away — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/
.env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# FastF1 cache (large downloaded session data)
cache/

# Generated data (can be regenerated by running main.py)
data/raw/
data/processed/

# Trained models (can be regenerated)
models/

# Generated outputs (plots and reports)
outputs/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Environment variables
.env
.env.local
